# Hugging Face — speech-to-text (use HUGGINGFACE_API_KEY or HF_TOKEN)
HUGGINGFACE_API_KEY=
HF_TOKEN=

# LLM (OpenAI-compatible HF router for CR agent)
LLM_BASE_URL=https://router.huggingface.co/v1
LLM_MODEL=google/gemma-4-31B-it:novita
LLM_MAX_AGENT_STEPS=12

# ASR_BACKEND: hf (uses hf-inference), hf-inference, fal-ai, auto
ASR_BACKEND=hf
# Prefer whisper-large-v3 on hf-inference; some smaller IDs return 404 on that endpoint.
ASR_MODEL=openai/whisper-large-v3

# Email — IMAP
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# Microsoft Graph (app registration)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SharePoint (Graph)
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# Pytest / manual integration checks (optional)
TEST_AUDIO_PATH=
TEST_GRAPH_MAIL_USER=
TEST_SHAREPOINT_FOLDER_PATH=

# Jira (CR agent)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_EPIC_ISSUE_TYPE=Epic
JIRA_STORY_ISSUE_TYPE=Story
JIRA_TASK_ISSUE_TYPE=Task
JIRA_EPIC_LINK_FIELD=customfield_10014
JIRA_VERIFY_SSL=true

# Smartsheet (plan agent line items)
SMARTSHEET_ACCESS_TOKEN=
SMARTSHEET_SHEET_ID=
SMARTSHEET_API_BASE=https://api.smartsheet.com/2.0
SMARTSHEET_VERIFY_SSL=true
SMARTSHEET_PHASE_COLUMN_TITLE=Phase
SMARTSHEET_START_COLUMN_TITLE=Start
SMARTSHEET_END_COLUMN_TITLE=End

# HTTP API (FastAPI / uvicorn)
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=*
